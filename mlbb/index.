<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <base href="/">
  <title>Draft Room By HCI - MLBB</title>
  <meta name="description" content="Draft Room By HCI - simulasi ban-pick MLBB real-time untuk coach dan analis." />
  <link rel="stylesheet" href="css/draft-room.css" />
</head>
<body>
  <main class="app-shell">
    <nav class="site-nav">
      <a class="nav-brand" href="/" aria-label="Kembali pilih game">
        <img src="./assets/hci-logo.webp" alt="Logo HCI" />
        <span>Draft Room By HCI</span>
      </a>
      <div class="nav-links">
        <a href="#create-room">Create Room</a>
        <a href="#about">About Us</a>
        <a href="#ads">Ads Slot</a>
        <a href="#follow">Follow HCI</a>
        <a href="/">Change Game</a>
      </div>
      <div class="nav-socials">
        <a class="icon-link ig" href="https://www.instagram.com/hci.official" target="_blank" rel="noopener" aria-label="Instagram HCI"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7.8 2h8.4A5.8 5.8 0 0 1 22 7.8v8.4A5.8 5.8 0 0 1 16.2 22H7.8A5.8 5.8 0 0 1 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2Zm0 2A3.8 3.8 0 0 0 4 7.8v8.4A3.8 3.8 0 0 0 7.8 20h8.4a3.8 3.8 0 0 0 3.8-3.8V7.8A3.8 3.8 0 0 0 16.2 4H7.8Zm8.7 2.25a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6Z"/></svg></a>
        <a class="icon-link wa" href="https://wa.me/6285136864822" target="_blank" rel="noopener" aria-label="WhatsApp HCI"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.5 3.5A11.8 11.8 0 0 0 2.7 18.2L2 22l3.9-.7A11.8 11.8 0 0 0 20.5 3.5ZM12 20a8.1 8.1 0 0 1-4.1-1.1l-.3-.2-2.3.4.4-2.2-.2-.4A8.2 8.2 0 1 1 12 20Zm4.5-6.1c-.2-.1-1.4-.7-1.6-.8-.2-.1-.4-.1-.6.1-.2.2-.7.8-.8 1-.2.2-.3.2-.6.1a6.7 6.7 0 0 1-3.3-2.9c-.2-.3 0-.4.1-.6l.4-.5c.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5s-.6-1.5-.8-2c-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.2.2-.9.9-.9 2.1s1 2.5 1.1 2.7c.1.2 1.9 3 4.7 4.2 2.8 1.1 2.8.7 3.3.7.5 0 1.5-.6 1.7-1.2.2-.6.2-1.1.2-1.2-.1-.2-.3-.3-.5-.4Z"/></svg></a>
      </div>
    </nav>

    <section class="ads-area" id="ads" aria-label="Advertising slots">
      <a class="ad-banner" href="#"><div><strong>Advertising Slot 01</strong><br><span>Pasang banner sponsor di Draft Room.</span></div></a>
      <a class="ad-banner" href="#"><div><strong>Advertising Slot 02</strong><br><span>Brand placement untuk komunitas.</span></div></a>
      <a class="ad-banner" href="#"><div><strong>Advertising Slot 03</strong><br><span>Promosi event, team, atau sponsor.</span></div></a>
      <a class="ad-banner" href="#"><div><strong>Advertising Slot 04</strong><br><span>Slot panjang untuk kampanye partner.</span></div></a>
    </section>

    <section class="landing">
      <div class="panel hero-card-main">
        <div class="hero-title-row">
          <img src="./assets/hci-logo.webp" alt="Logo HCI" />
          <div>
            <span class="eyebrow">By HCI · Honor of Kings Community Indonesia</span>
            <h1>Draft Room By HCI</h1>
          </div>
        </div>
        <p>Website simulasi draft MLBB berbasis Room ID untuk latihan coach, analis, dan tim komunitas. Buat room, bagikan ID, lalu mulai simulasi ban-pick secara real-time.</p>
        <div class="hero-actions">
          <a class="primary-btn" href="#create-room">Create Room</a>
          <a class="secondary-btn" href="#join-room">Masukkan ID Room</a>
        </div>
      </div>
      <div class="quick-info">
        <div class="panel info-card"><span class="eyebrow">Real-Time</span><h3>Ban-pick langsung sinkron</h3><p>Kedua tim melihat draft yang sama tanpa refresh manual.</p></div>
        <div class="panel info-card"><span class="eyebrow">Draft Result</span><h3>Result bisa di-download PNG</h3><p>Setelah draft selesai, hasil bisa disimpan untuk evaluasi.</p></div>
        <div class="panel info-card"><span class="eyebrow">Best of 3</span><h3>Next Game siap</h3><p>Lanjut Game 2 / Game 3 dari room yang sama.</p></div>
      </div>
    </section>

    <section class="panel setup-panel" id="create-room">
      <div>
        <span class="eyebrow">MLBB Simulator</span>
        <h2>Mulai Draft</h2>
        <p>Buat room baru sebagai host, atau masuk menggunakan Room ID dari host. Host yang membuat room bisa menghapus room miliknya.</p>
      </div>
      <div class="setup-grid">
        <div class="card soft-card">
          <h3>Create Room</h3>
          <p>Host otomatis menjadi Team A dan memiliki akses delete room.</p>
          <button class="primary-btn" id="createRoomBtn" disabled>Create Room</button>
        </div>
        <div class="card soft-card" id="join-room">
          <h3>Masukkan ID Room</h3>
          <p>Masuk room dari host, lalu pilih Team B atau spectator.</p>
          <div class="join-row">
            <input id="roomIdInput" type="text" placeholder="Contoh: MLBB-4821" autocomplete="off" />
            <button class="secondary-btn" id="joinRoomBtn" disabled>Join</button>
          </div>
        </div>
      </div>
      <div class="notice warning" id="firebaseNotice" hidden>Firebase belum dikonfigurasi. Edit file <strong>js/firebase-config.js</strong> agar fitur room real-time bisa jalan.</div>
      <div class="notice compact">Status: <strong id="connectionStatus">Menghubungkan Firebase...</strong></div>
    </section>

    <section class="room-layout" id="roomPanel" hidden>
      <aside class="panel room-sidebar">
        <div class="room-meta"><span class="eyebrow">Room ID</span><div class="room-code-row"><strong id="roomCodeDisplay">-</strong><button class="tiny-btn" id="copyRoomBtn">Copy</button></div></div>
        <div class="room-meta"><span class="eyebrow">Status</span><strong id="roomStatusDisplay">Lobby</strong></div>
        <div class="side-picker" id="sidePicker"><button class="side-btn" data-side="A">Masuk Team A</button><button class="side-btn" data-side="B">Masuk Team B</button><button class="side-btn ghost" data-side="SPECTATOR">Spectator</button></div>
        <div class="current-turn-card"><span class="eyebrow">Giliran Sekarang</span><h2 id="currentTurnText">Menunggu draft dimulai</h2><p id="currentTurnHelp">Host dapat memulai draft setelah Team B masuk.</p><div class="timer-wrap"><div class="timer-value" id="timerValue">--</div><div class="timer-label">timer visual</div></div></div>
        <div class="action-stack"><button class="primary-btn" id="startDraftBtn" hidden>Mulai Draft</button><button class="secondary-btn" id="copyResultBtn" hidden>Copy Result</button><button class="danger-btn" id="deleteRoomBtn" hidden>Hapus Room</button><button class="ghost-btn" id="leaveRoomBtn">Keluar Tampilan</button></div>
        <div class="notice compact"><strong>Catatan:</strong> Room ID hanya bisa dipakai sesuai game yang dipilih.</div>
      </aside>

      <section class="draft-stage">
        <div class="draft-focus-header" id="draftFocusHeader">
          <div><span class="eyebrow" id="focusRoomText">-</span><h1 id="gameHeadline">Game 1 / Best of 3</h1></div>
          <div class="focus-actions"><button class="tiny-btn" id="copyRoomTopBtn">Copy ID</button><button class="secondary-btn" id="downloadResultTopBtn" hidden>Download Result</button><button class="danger-btn" id="deleteRoomTopBtn" hidden>Delete Room</button></div>
        </div>
        <div class="teams-grid" id="draftBoard">
          <div class="team-card team-a"><div class="team-head"><div><span class="eyebrow">Blue Side</span><h2>Team A</h2></div><span class="team-state" id="teamAState">Kosong</span></div><div class="slot-section"><h3>Ban</h3><div class="slot-grid ban-grid" id="teamABans"></div></div><div class="slot-section"><h3>Pick</h3><div class="slot-grid pick-grid" id="teamAPicks"></div></div></div>
          <div class="team-card team-b"><div class="team-head"><div><span class="eyebrow">Red Side</span><h2>Team B</h2></div><span class="team-state" id="teamBState">Kosong</span></div><div class="slot-section"><h3>Ban</h3><div class="slot-grid ban-grid" id="teamBBans"></div></div><div class="slot-section"><h3>Pick</h3><div class="slot-grid pick-grid" id="teamBPicks"></div></div></div>
        </div>

        <section class="panel draft-result-panel" id="draftResultPanel" hidden>
          <div class="result-header"><div><span class="eyebrow">Draft Result</span><h2 id="resultGameTitle">Game 1 Draft Result</h2></div><p>Hasil draft otomatis muncul setelah ban-pick selesai.</p></div>
          <div class="result-board"><div class="result-team result-team-a"><div class="result-team-head"><span class="eyebrow">Blue Side</span><h3>Team A</h3></div><div class="result-block"><h4>Ban</h4><div class="result-ban-row" id="resultABans"></div></div><div class="result-block"><h4>Pick</h4><div class="result-pick-column" id="resultAPicks"></div></div></div><div class="result-team result-team-b"><div class="result-team-head"><span class="eyebrow">Red Side</span><h3>Team B</h3></div><div class="result-block"><h4>Ban</h4><div class="result-ban-row" id="resultBBans"></div></div><div class="result-block"><h4>Pick</h4><div class="result-pick-column" id="resultBPicks"></div></div></div></div>
        </section>

        <div class="panel heroes-panel" id="heroPanel">
          <div class="heroes-toolbar"><div><span class="eyebrow">Hero Database</span><h2>Pilih Hero</h2></div><div class="toolbar-actions"><input id="heroSearch" type="search" placeholder="Cari hero..." /><div class="role-filters" id="laneFilterButtons" aria-label="Filter role hero"></div></div></div>
          <div class="draft-sequence" id="draftSequence"></div><div class="hero-grid" id="heroGrid"></div>
        </div>
      </section>
    </section>

    <section class="about-social" id="about">
      <div class="panel"><span class="eyebrow">About Us</span><h2>Kenapa Draft Room By HCI dibuat?</h2><p>Draft Room By HCI dibuat sebagai tools latihan untuk coach, analis, dan tim komunitas agar bisa mengasah pembacaan draft, prioritas ban-pick, dan evaluasi komposisi sebelum scrim atau match.</p></div>
      <div class="panel" id="follow"><span class="eyebrow">Follow HCI</span><h2>Social Media HCI</h2><p>Ikuti HCI untuk update tournament, community project, dan informasi Draft Room.</p><div class="social-button-row"><a class="social-chip ig" href="https://www.instagram.com/hci.official" target="_blank" rel="noopener"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7.8 2h8.4A5.8 5.8 0 0 1 22 7.8v8.4A5.8 5.8 0 0 1 16.2 22H7.8A5.8 5.8 0 0 1 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2Zm0 2A3.8 3.8 0 0 0 4 7.8v8.4A3.8 3.8 0 0 0 7.8 20h8.4a3.8 3.8 0 0 0 3.8-3.8V7.8A3.8 3.8 0 0 0 16.2 4H7.8Zm8.7 2.25a1.25 1.25 0 1 1 0 2.5 1.25 1.25 0 0 1 0-2.5ZM12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10Zm0 2a3 3 0 1 0 0 6 3 3 0 0 0 0-6Z"/></svg> @hci.official</a><a class="social-chip wa" href="https://wa.me/6285136864822" target="_blank" rel="noopener"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.5 3.5A11.8 11.8 0 0 0 2.7 18.2L2 22l3.9-.7A11.8 11.8 0 0 0 20.5 3.5ZM12 20a8.1 8.1 0 0 1-4.1-1.1l-.3-.2-2.3.4.4-2.2-.2-.4A8.2 8.2 0 1 1 12 20Zm4.5-6.1c-.2-.1-1.4-.7-1.6-.8-.2-.1-.4-.1-.6.1-.2.2-.7.8-.8 1-.2.2-.3.2-.6.1a6.7 6.7 0 0 1-3.3-2.9c-.2-.3 0-.4.1-.6l.4-.5c.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5s-.6-1.5-.8-2c-.2-.5-.4-.4-.6-.4h-.5c-.2 0-.5.1-.7.3-.2.2-.9.9-.9 2.1s1 2.5 1.1 2.7c.1.2 1.9 3 4.7 4.2 2.8 1.1 2.8.7 3.3.7.5 0 1.5-.6 1.7-1.2.2-.6.2-1.1.2-1.2-.1-.2-.3-.3-.5-.4Z"/></svg> WhatsApp HCI</a></div></div>
    </section>
  </main>

  <div class="session-modal" id="sessionModal" hidden>
    <div class="session-modal-card"><span class="eyebrow">Draft Selesai</span><h2 id="sessionModalTitle">Game 1 selesai</h2><p>Pilih aksi berikutnya untuk sesi draft ini.</p><div class="modal-actions"><button class="primary-btn" id="nextGameBtn">Next Game</button><button class="secondary-btn" id="backLobbyBtn">Back to Lobby</button><button class="danger-btn" id="downloadResultBtn">Download Result</button></div></div>
  </div>
  <div class="toast" id="toast" hidden></div>

  <script src="https://www.gstatic.com/firebasejs/10.12.5/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.12.5/firebase-auth-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.12.5/firebase-firestore-compat.js"></script>
  <script>window.HCI_GAME_CONFIG = { gameKey: "MLBB", gameName: "MLBB Draft Room", roomPrefix: "MLBB", roles: ['ALL','EXP Lane','Jungle','Mid Lane','Gold Lane','Roam'] };</script>
  <script src="./js/firebase-config.js"></script>
  <script src="./js/heroes-mlbb.js"></script>
  <script src="./js/draft-room.js"></script>
</body>
</html>
