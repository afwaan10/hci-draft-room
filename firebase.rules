rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    match /draftRooms/{roomId} {
      allow read, create, update, delete: if signedIn();
    }
    match /heroes/{heroId} {
      allow read, write: if signedIn();
    }
  }
}
