rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Anonymous Authentication is intentionally rejected.
    function signedIn() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function isAdmin() {
      return signedIn() && (
        request.auth.token.get('admin', false) == true
        || request.auth.token.get('email', '') == 'muhammaddeha03@gmail.com'
      );
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function changedOnly(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    function updatedNow() {
      return request.resource.data.updatedAt == request.time;
    }

    // ------------------------------------------------------------------
    // USER PROFILE
    // ------------------------------------------------------------------

    match /users/{userId} {
      function allowedFields() {
        return [
          'fullName', 'username', 'email', 'photoURL', 'bio', 'country',
          'mainGame', 'mainRole', 'rank', 'playerId',
          'createdAt', 'updatedAt'
        ];
      }

      function validProfile() {
        return request.resource.data.keys().hasOnly(allowedFields())
          && request.resource.data.keys().hasAll(['email', 'updatedAt'])
          && request.resource.data.email == request.auth.token.get('email', '')
          && request.resource.data.get('fullName', '') is string
          && request.resource.data.get('fullName', '').size() <= 80
          && request.resource.data.get('username', '') is string
          && request.resource.data.get('username', '').size() <= 20
          && request.resource.data.get('photoURL', '') is string
          && request.resource.data.get('photoURL', '').size() <= 2000
          && request.resource.data.get('bio', '') is string
          && request.resource.data.get('bio', '').size() <= 500
          && request.resource.data.get('country', '') is string
          && request.resource.data.get('country', '').size() <= 80
          && request.resource.data.get('mainGame', '') is string
          && request.resource.data.get('mainGame', '').size() <= 40
          && request.resource.data.get('mainRole', '') is string
          && request.resource.data.get('mainRole', '').size() <= 40
          && request.resource.data.get('rank', '') is string
          && request.resource.data.get('rank', '').size() <= 60
          && request.resource.data.get('playerId', '') is string
          && request.resource.data.get('playerId', '').size() <= 80
          && request.resource.data.updatedAt == request.time;
      }

      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();

      // createdAt is optional for compatibility with existing Google users.
      allow create: if isOwner(userId)
        && validProfile()
        && request.resource.data.get('createdAt', request.time) == request.time;

      allow update: if isOwner(userId)
        && validProfile()
        && request.resource.data.get(
             'createdAt',
             resource.data.get('createdAt', request.time)
           ) == resource.data.get('createdAt', request.time)
        && changedOnly(allowedFields());

      allow delete: if isAdmin();
    }

    // ------------------------------------------------------------------
    // UNIQUE USERNAME RESERVATION
    // ------------------------------------------------------------------

    match /usernames/{username} {
      function validUsername() {
        return username.matches('^[a-z0-9_]{3,20}$')
          && request.resource.data.keys().hasOnly([
            'uid', 'email', 'createdAt', 'updatedAt'
          ])
          && request.resource.data.keys().hasAll(['uid', 'email', 'updatedAt'])
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.email == request.auth.token.get('email', '')
          && request.resource.data.updatedAt == request.time;
      }

      // Required by the current "Email or Username" login flow.
      // Only an exact document can be read; collection enumeration is blocked.
      allow get: if true;
      allow list: if isAdmin();

      allow create: if signedIn()
        && validUsername()
        && request.resource.data.get('createdAt', request.time) == request.time;

      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && validUsername()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.get(
             'createdAt',
             resource.data.get('createdAt', request.time)
           ) == resource.data.get('createdAt', request.time);

      allow delete: if signedIn()
        && (resource.data.uid == request.auth.uid || isAdmin());
    }

    // ------------------------------------------------------------------
    // TEAM CENTER
    // ------------------------------------------------------------------

    match /teams/{teamId} {
      function validTeam() {
        return request.resource.data.keys().hasOnly([
          'name', 'tag', 'logoURL', 'game', 'region', 'description',
          'leader', 'coach', 'manager', 'members',
          'ownerUid', 'leaderUid', 'createdAt', 'updatedAt'
        ])
          && request.resource.data.keys().hasAll([
            'name', 'tag', 'logoURL', 'game', 'region', 'description',
            'leader', 'coach', 'manager', 'members',
            'ownerUid', 'leaderUid', 'updatedAt'
          ])
          && request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() <= 80
          && request.resource.data.tag is string
          && request.resource.data.tag.matches('^[A-Z0-9]{2,8}$')
          && request.resource.data.logoURL is string
          && request.resource.data.logoURL.size() <= 2000
          && request.resource.data.game in [
            'Honor of Kings', 'Mobile Legends', 'Arena of Valor'
          ]
          && request.resource.data.region is string
          && request.resource.data.region.size() <= 80
          && request.resource.data.description is string
          && request.resource.data.description.size() <= 1000
          && request.resource.data.leader is string
          && request.resource.data.leader.size() <= 80
          && request.resource.data.coach is string
          && request.resource.data.coach.size() <= 80
          && request.resource.data.manager is string
          && request.resource.data.manager.size() <= 80
          && request.resource.data.members is list
          && request.resource.data.members.size() >= 2
          && request.resource.data.members.size() <= 7
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.leaderUid == request.auth.uid
          && request.resource.data.updatedAt == request.time;
      }

      // The current Team Center queries with where('ownerUid', '==', uid).
      allow get, list: if signedIn()
        && (resource.data.ownerUid == request.auth.uid || isAdmin());

      allow create: if signedIn()
        && validTeam()
        && request.resource.data.createdAt == request.time;

      allow update: if signedIn()
        && resource.data.ownerUid == request.auth.uid
        && validTeam()
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.leaderUid == resource.data.leaderUid
        && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if signedIn()
        && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    // ------------------------------------------------------------------
    // SAVED MAP PLANS
    // ------------------------------------------------------------------

    match /mapPlans/{planId} {
      function validMapPlan() {
        return request.resource.data.keys().hasOnly([
          'ownerUid', 'game', 'title', 'note', 'markers', 'routes',
          'createdAt', 'updatedAt'
        ])
          && request.resource.data.keys().hasAll([
            'ownerUid', 'game', 'title', 'note', 'markers', 'routes',
            'updatedAt'
          ])
          && request.resource.data.ownerUid == request.auth.uid
          && request.resource.data.game in ['hok', 'mlbb', 'HOK', 'MLBB']
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 100
          && request.resource.data.note is string
          && request.resource.data.note.size() <= 2000
          && request.resource.data.markers is list
          && request.resource.data.markers.size() <= 300
          && request.resource.data.routes is list
          && request.resource.data.routes.size() <= 150
          && request.resource.data.updatedAt == request.time;
      }

      allow get, list: if signedIn()
        && (resource.data.ownerUid == request.auth.uid || isAdmin());

      allow create: if signedIn()
        && validMapPlan()
        && request.resource.data.createdAt == request.time;

      allow update: if signedIn()
        && resource.data.ownerUid == request.auth.uid
        && validMapPlan()
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if signedIn()
        && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    // ------------------------------------------------------------------
    // REAL-TIME DRAFT ROOMS
    // ------------------------------------------------------------------

    function roomHost(data) {
      return signedIn() && data.hostUid == request.auth.uid;
    }

    function roomParticipant(data) {
      return signedIn() && (
        data.hostUid == request.auth.uid
        || data.teamAUid == request.auth.uid
        || data.teamBUid == request.auth.uid
        || request.auth.uid in data.get('spectatorUids', [])
      );
    }

    function roomIdentityUnchanged() {
      return request.resource.data.id == resource.data.id
        && request.resource.data.hostUid == resource.data.hostUid
        && request.resource.data.game == resource.data.game
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function validRoomCreate(roomId) {
      return request.resource.data.keys().hasAll([
        'id', 'roomName', 'game', 'gameNumber', 'status',
        'hostUid', 'hostEmail', 'teamAUid', 'teamBUid',
        'teamAName', 'teamBName', 'spectatorUids',
        'turnIndex', 'bansA', 'bansB', 'picksA', 'picksB',
        'selectedHeroIds', 'finishedGames', 'createdAt', 'updatedAt'
      ])
        && request.resource.data.id == roomId
        && request.resource.data.game in ['hok', 'mlbb', 'HOK', 'MLBB']
        && request.resource.data.gameNumber == 1
        && request.resource.data.status == 'lobby'
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.hostEmail == request.auth.token.get('email', '')
        && request.resource.data.teamAUid == request.auth.uid
        && request.resource.data.teamBUid == ''
        && request.resource.data.roomName is string
        && request.resource.data.roomName.size() > 0
        && request.resource.data.roomName.size() <= 36
        && request.resource.data.teamAName is string
        && request.resource.data.teamAName.size() > 0
        && request.resource.data.teamAName.size() <= 24
        && request.resource.data.teamBName is string
        && request.resource.data.teamBName.size() > 0
        && request.resource.data.teamBName.size() <= 24
        && request.resource.data.spectatorUids is list
        && request.resource.data.spectatorUids.size() == 0
        && request.resource.data.turnIndex == 0
        && request.resource.data.bansA is list
        && request.resource.data.bansA.size() == 0
        && request.resource.data.bansB is list
        && request.resource.data.bansB.size() == 0
        && request.resource.data.picksA is list
        && request.resource.data.picksA.size() == 0
        && request.resource.data.picksB is list
        && request.resource.data.picksB.size() == 0
        && request.resource.data.selectedHeroIds is list
        && request.resource.data.selectedHeroIds.size() == 0
        && request.resource.data.finishedGames is list
        && request.resource.data.finishedGames.size() == 0
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
    }

    function validSelfLobbyChange() {
      return resource.data.status == 'lobby'
        && request.resource.data.status == 'lobby'
        && changedOnly([
          'teamAUid', 'teamBUid', 'spectatorUids', 'updatedAt'
        ])
        && updatedNow()

        // Team A may only remain unchanged, be claimed if empty,
        // or be released by its current owner.
        && (
          request.resource.data.teamAUid == resource.data.teamAUid
          || (
            resource.data.teamAUid == ''
            && request.resource.data.teamAUid == request.auth.uid
          )
          || (
            resource.data.teamAUid == request.auth.uid
            && request.resource.data.teamAUid == ''
          )
        )

        // Same protection for Team B.
        && (
          request.resource.data.teamBUid == resource.data.teamBUid
          || (
            resource.data.teamBUid == ''
            && request.resource.data.teamBUid == request.auth.uid
          )
          || (
            resource.data.teamBUid == request.auth.uid
            && request.resource.data.teamBUid == ''
          )
        )

        // Spectator mode may keep the old list or add only the current user.
        && (
          request.resource.data.spectatorUids ==
            resource.data.get('spectatorUids', [])
          || (
            request.resource.data.spectatorUids is list
            && request.resource.data.spectatorUids.hasAll(
              resource.data.get('spectatorUids', [])
            )
            && request.resource.data.spectatorUids.size() <=
              resource.data.get('spectatorUids', []).size() + 1
            && request.auth.uid in request.resource.data.spectatorUids
          )
        )

        // The caller must end up as a team member or spectator.
        && (
          request.resource.data.teamAUid == request.auth.uid
          || request.resource.data.teamBUid == request.auth.uid
          || request.auth.uid in request.resource.data.spectatorUids
        );
    }

    function activeSide(data) {
      return data.game == 'MLBB'
        ? [
            'BLUE','RED','BLUE','RED','BLUE','RED',
            'BLUE','RED','RED','BLUE','BLUE','RED',
            'RED','BLUE','RED','BLUE','RED','BLUE','BLUE','RED'
          ][data.turnIndex]
        : [
            'BLUE','RED','BLUE','RED','BLUE','RED','RED','BLUE',
            'BLUE','RED','RED','BLUE','RED','BLUE','RED','BLUE',
            'BLUE','RED'
          ][data.turnIndex];
    }

    function activeAction(data) {
      return data.game == 'MLBB'
        ? [
            'ban','ban','ban','ban','ban','ban',
            'pick','pick','pick','pick','pick','pick',
            'ban','ban','ban','ban','pick','pick','pick','pick'
          ][data.turnIndex]
        : [
            'ban','ban','ban','ban',
            'pick','pick','pick','pick','pick','pick',
            'ban','ban','ban','ban','pick','pick','pick','pick'
          ][data.turnIndex];
    }

    function validTurnIndex(data) {
      return (
        data.game == 'HOK'
        && data.turnIndex >= 0
        && data.turnIndex < 18
      ) || (
        data.game == 'MLBB'
        && data.turnIndex >= 0
        && data.turnIndex < 20
      );
    }

    function activeTeam(data) {
      return activeSide(data) == 'BLUE'
        ? (data.gameNumber % 2 == 1 ? 'A' : 'B')
        : (data.gameNumber % 2 == 1 ? 'B' : 'A');
    }

    function activeTeamUid(data) {
      return activeTeam(data) == 'A' ? data.teamAUid : data.teamBUid;
    }

    function finalTurn(data) {
      return (
        data.game == 'HOK' && data.turnIndex == 17
      ) || (
        data.game == 'MLBB' && data.turnIndex == 19
      );
    }

    function activeSelectionCount(data) {
      return (
        data.game == 'HOK'
        && activeAction(data) == 'pick'
        && data.turnIndex in [5, 7, 15]
      ) ? 2 : 1;
    }

    function heroesAdded(oldList, newList, oldSelected, newSelected, count) {
      return newList.size() == oldList.size() + count
        && newList.hasAll(oldList)
        && newSelected.size() == oldSelected.size() + count
        && newSelected.hasAll(oldSelected)
        && newList[oldList.size()] == newSelected[oldSelected.size()]
        && (
          count == 1
          || newList[oldList.size() + 1] ==
            newSelected[oldSelected.size() + 1]
        );
    }

    function correctDraftListChanged() {
      return (
        activeTeam(resource.data) == 'A'
        && activeAction(resource.data) == 'ban'
        && heroesAdded(
          resource.data.bansA,
          request.resource.data.bansA,
          resource.data.selectedHeroIds,
          request.resource.data.selectedHeroIds,
          activeSelectionCount(resource.data)
        )
        && request.resource.data.bansB == resource.data.bansB
        && request.resource.data.picksA == resource.data.picksA
        && request.resource.data.picksB == resource.data.picksB
      ) || (
        activeTeam(resource.data) == 'B'
        && activeAction(resource.data) == 'ban'
        && heroesAdded(
          resource.data.bansB,
          request.resource.data.bansB,
          resource.data.selectedHeroIds,
          request.resource.data.selectedHeroIds,
          activeSelectionCount(resource.data)
        )
        && request.resource.data.bansA == resource.data.bansA
        && request.resource.data.picksA == resource.data.picksA
        && request.resource.data.picksB == resource.data.picksB
      ) || (
        activeTeam(resource.data) == 'A'
        && activeAction(resource.data) == 'pick'
        && heroesAdded(
          resource.data.picksA,
          request.resource.data.picksA,
          resource.data.selectedHeroIds,
          request.resource.data.selectedHeroIds,
          activeSelectionCount(resource.data)
        )
        && request.resource.data.bansA == resource.data.bansA
        && request.resource.data.bansB == resource.data.bansB
        && request.resource.data.picksB == resource.data.picksB
      ) || (
        activeTeam(resource.data) == 'B'
        && activeAction(resource.data) == 'pick'
        && heroesAdded(
          resource.data.picksB,
          request.resource.data.picksB,
          resource.data.selectedHeroIds,
          request.resource.data.selectedHeroIds,
          activeSelectionCount(resource.data)
        )
        && request.resource.data.bansA == resource.data.bansA
        && request.resource.data.bansB == resource.data.bansB
        && request.resource.data.picksA == resource.data.picksA
      );
    }

    function validTeamDraftAction() {
      return resource.data.status == 'drafting'
        && validTurnIndex(resource.data)
        && activeTeamUid(resource.data) == request.auth.uid
        && roomIdentityUnchanged()
        && changedOnly([
          'bansA', 'bansB', 'picksA', 'picksB',
          'selectedHeroIds', 'turnIndex', 'status',
          'currentTurnSeconds', 'currentTurnStartedAt', 'updatedAt'
        ])
        && updatedNow()
        && request.resource.data.turnIndex ==
          resource.data.turnIndex + activeSelectionCount(resource.data)
        && request.resource.data.status == (
          finalTurn(resource.data) ? 'finished' : 'drafting'
        )
        && correctDraftListChanged()
        && (
          (
            request.resource.data.status == 'finished'
            && request.resource.data.currentTurnStartedAt == null
            && request.resource.data.currentTurnSeconds == null
          )
          || (
            request.resource.data.status == 'drafting'
            && request.resource.data.currentTurnSeconds in [30, 45]
            && (
              request.resource.data.currentTurnStartedAt == request.time
              || request.resource.data.currentTurnStartedAt ==
                resource.data.currentTurnStartedAt
            )
          )
        );
    }

    function validParticipantLeaveEvent() {
      return roomParticipant(resource.data)
        && roomIdentityUnchanged()
        && changedOnly(['lastParticipantEvent', 'updatedAt'])
        && updatedNow()
        && request.resource.data.lastParticipantEvent is map
        && request.resource.data.lastParticipantEvent.keys().hasOnly([
          'type', 'uid', 'name', 'role', 'atMillis'
        ])
        && request.resource.data.lastParticipantEvent.type == 'left'
        && request.resource.data.lastParticipantEvent.uid == request.auth.uid
        && request.resource.data.lastParticipantEvent.name is string
        && request.resource.data.lastParticipantEvent.name.size() <= 120
        && request.resource.data.lastParticipantEvent.role is string
        && request.resource.data.lastParticipantEvent.role.size() <= 20
        && request.resource.data.lastParticipantEvent.atMillis is int;
    }

    function validAutomaticTransition() {
      return roomParticipant(resource.data)
        && roomIdentityUnchanged()
        && (
          (
            resource.data.status == 'preparing'
            && resource.data.prepareEndsAt is timestamp
            && request.time >= resource.data.prepareEndsAt
            && request.resource.data.status == 'drafting'
            && changedOnly([
              'status', 'currentTurnStartedAt', 'currentTurnSeconds',
              'prepareEndsAt', 'updatedAt'
            ])
            && request.resource.data.currentTurnStartedAt == request.time
            && request.resource.data.prepareEndsAt == null
          )
          || (
            resource.data.status == 'intermission'
            && resource.data.nextGameStartsAt is timestamp
            && request.time >= resource.data.nextGameStartsAt
            && request.resource.data.status == 'drafting'
            && changedOnly([
              'status', 'turnIndex', 'currentTurnStartedAt',
              'currentTurnSeconds', 'nextGameStartsAt', 'updatedAt'
            ])
            && request.resource.data.turnIndex == 0
            && request.resource.data.currentTurnStartedAt == request.time
            && request.resource.data.nextGameStartsAt == null
          )
        )
        && request.resource.data.currentTurnSeconds in [30, 45]
        && updatedNow();
    }

    match /draftRooms/{roomId} {
      // Exact room-code access is available to authenticated users.
      allow get: if signedIn();
      allow list: if isAdmin();

      allow create: if isAdmin()
        || (signedIn() && validRoomCreate(roomId));

      allow update: if isAdmin()
        || (
          signedIn()
          && roomIdentityUnchanged()
          && (
            // Host owns the room and controls lobby/session actions.
            (roomHost(resource.data) && updatedNow())
            || validSelfLobbyChange()
            || validTeamDraftAction()
            || validParticipantLeaveEvent()
            || validAutomaticTransition()
          )
        );

      allow delete: if isAdmin() || roomHost(resource.data);

      match /activityLogs/{logId} {
        function parentRoom() {
          return get(
            /databases/$(database)/documents/draftRooms/$(roomId)
          ).data;
        }

        allow read: if isAdmin() || roomParticipant(parentRoom());

        allow create: if signedIn()
          && (isAdmin() || roomParticipant(parentRoom()))
          && request.resource.data.keys().hasOnly([
            'action', 'actorUid', 'actorEmail', 'actorRole',
            'game', 'roomId', 'meta', 'createdAt'
          ])
          && request.resource.data.actorUid == request.auth.uid
          && request.resource.data.actorEmail ==
            request.auth.token.get('email', '')
          && request.resource.data.roomId == roomId
          && request.resource.data.createdAt == request.time;

        allow update, delete: if isAdmin();
      }
    }

    // ------------------------------------------------------------------
    // DRAFT HISTORY
    // ------------------------------------------------------------------

    match /draftHistory/{historyId} {
      function validHistoryCreate() {
        return request.resource.data.keys().hasOnly([
          'id', 'roomId', 'roomName', 'game', 'gameNumber', 'bestOf',
          'seriesKey', 'seriesMode', 'seriesLabel',
          'teamAName', 'teamBName', 'teamASide', 'teamBSide',
          'blueTeamKey', 'redTeamKey', 'blueTeamName', 'redTeamName',
          'bansA', 'bansB', 'picksA', 'picksB',
          'blueBans', 'redBans', 'bluePicks', 'redPicks',
          'participantUids', 'hostUid', 'simulation',
          'finishedAtMillis', 'createdAt'
        ])
          && request.resource.data.id == historyId
          && request.resource.data.hostUid == request.auth.uid
          && request.resource.data.participantUids is list
          && request.auth.uid in request.resource.data.participantUids
          && request.resource.data.createdAt == request.time;
      }

      // The current client checks whether an exact history ID exists before
      // creating it, so exact get remains available to signed-in users.
      allow get: if signedIn();

      // List queries must include:
      // where('participantUids', 'array-contains', request.auth.uid)
      allow list: if isAdmin()
        || (
          signedIn()
          && request.auth.uid in resource.data.participantUids
        );

      allow create: if isAdmin()
        || (signedIn() && validHistoryCreate());

      // Completed history is immutable.
      allow update, delete: if false;
    }

    // ------------------------------------------------------------------
    // GAME DATABASES
    // ------------------------------------------------------------------

    match /heroes/{heroId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /items/{itemId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // ------------------------------------------------------------------
    // EXISTING V41 ADMIN COLLECTIONS
    // ------------------------------------------------------------------

    match /userAccess/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /siteConfig/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /sponsors/{sponsorId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /communityLinks/{linkId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    // Deny every collection not explicitly declared above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
